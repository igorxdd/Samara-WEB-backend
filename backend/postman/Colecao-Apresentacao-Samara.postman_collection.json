            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation CreateTask($input: CreateTaskInput!) { createTask(input: $input) { id title status urgency } }\",\n  \"variables\": {\n    \"input\": {\n      \"title\": \"Organizar conteudo de GraphQL\",\n      \"description\": \"Exemplos praticos para a aula da Samara\",\n      \"deadline\": \"2026-03-20T18:00:00.000Z\",\n      \"urgency\": \"HIGH\"\n    }\n  }\n}"
            },
