            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation Login($input: LoginInput!) { login(input: $input) { token user { id name email } } }\",\n  \"variables\": {\n    \"input\": {\n      \"email\": \"{{emailGraphql}}\",\n      \"password\": \"{{senhaPadrao}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{urlBase}}/graphql",
              "host": [
                "{{urlBase}}"
              ],
              "path": [
                "graphql"
              ]
            }
