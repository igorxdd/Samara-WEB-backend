    {
      "name": "API GraphQL",
      "item": [
        {
          "name": "13. Cadastrar (Samara GraphQL)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const email = `samara.graphql.${Date.now()}@email.com`;",
                  "pm.collectionVariables.set('emailGraphql', email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation Register($input: RegisterInput!) { register(input: $input) { token user { id name email } } }\",\n  \"variables\": {\n    \"input\": {\n      \"name\": \"Samara Oliveira\",\n      \"email\": \"{{emailGraphql}}\",\n      \"password\": \"{{senhaPadrao}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{urlBase}}/graphql",
              "host": [
                "{{urlBase}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "14. Entrar GraphQL (salvar token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const corpo = pm.response.json();",
                  "if (corpo && corpo.data && corpo.data.login && corpo.data.login.token) {",
                  "  pm.collectionVariables.set('tokenAcesso', corpo.data.login.token);",
                  "}"
